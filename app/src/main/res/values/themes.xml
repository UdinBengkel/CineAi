<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════
         BASE THEME
         ═══════════════════════════════════════════ -->
    <style name="Theme.CineAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_red</item>
        <item name="colorPrimaryVariant">@color/brand_red_dark</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorSecondary">@color/brand_red</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="chipStyle">@style/Widget.CineAI.Chip</item>
        <item name="materialCardViewStyle">@style/Widget.CineAI.Card</item>
        <item name="bottomNavigationStyle">@style/Widget.CineAI.BottomNav</item>
    </style>

    <style name="Theme.CineAI.Splash" parent="Theme.CineAI">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- ═══════════════════════════════════════════
         TYPOGRAPHY — parent harus TextAppearance.MaterialComponents.*
         ═══════════════════════════════════════════ -->

    <style name="TextAppearance.CineAI.PageTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.CineAI.AppName" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.CineAI.HeroTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.CineAI.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.CineAI.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_red</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <style name="TextAppearance.CineAI.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.CineAI.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <!-- ═══════════════════════════════════════════
         COMPONENTS
         ═══════════════════════════════════════════ -->

    <style name="Widget.CineAI.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_primary</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <style name="Widget.CineAI.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="Widget.CineAI.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="chipCornerRadius">8dp</item>
    </style>

    <style name="Widget.CineAI.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.CineAI.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_red</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="Widget.CineAI.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/stroke</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">10dp</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="Widget.CineAI.Button.Icon" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/stroke</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">10dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

</resources>
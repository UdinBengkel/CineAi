<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_glow_bg">

    <!-- Konten tengah -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo rounded square merah -->
        <ImageView
            android:layout_width="@dimen/splash_logo_size"
            android:layout_height="@dimen/splash_logo_size"
            android:src="@drawable/ic_splash_logo"
            android:contentDescription="@string/app_name" />

        <!-- Nama app: CINE (putih) + AI (merah) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name_prefix"
                android:textColor="@color/text_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name_suffix"
                android:textColor="@color/brand_red"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_tagline"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:letterSpacing="0.16"
            android:fontFamily="sans-serif-medium" />

        <!-- Lokasi GPS -->
        <TextView
            android:id="@+id/tv_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_location_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:visibility="invisible" />

        <!-- Loading line merah -->
        <View
            android:id="@+id/loading_line_track"
            android:layout_width="80dp"
            android:layout_height="@dimen/progress_bar_height"
            android:layout_marginTop="56dp"
            android:background="@color/bg_elevated"
            android:backgroundTint="@color/bg_elevated" />

        <!-- Line fill (animasi di SplashActivity) -->
        <View
            android:id="@+id/loading_line_fill"
            android:layout_width="0dp"
            android:layout_height="@dimen/progress_bar_height"
            android:layout_marginTop="-3dp"
            android:background="@color/brand_red" />

    </LinearLayout>

</FrameLayout>
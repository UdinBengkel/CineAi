<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ══════════════════════════════════════════
         COLLAPSING HEADER — Backdrop + Overlay
         ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/backdrop_height"
        android:fitsSystemWindows="true"
        android:background="@color/bg_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/bg_primary"
            app:statusBarScrim="@color/bg_primary"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <!-- Backdrop image -->
            <ImageView
                android:id="@+id/iv_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/surface"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6" />

            <!-- Heavy gradient overlay bawah → bg_primary -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_hero" />

            <!-- Toolbar: hanya back button -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationIconTint="@color/text_primary" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════
         BODY CONTENT
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- ── Poster + Info Row ─────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Poster -->
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/poster_detail_width"
                    android:layout_height="@dimen/poster_detail_height"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface">

                    <ImageView
                        android:id="@+id/iv_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/placeholder_poster" />
                </androidx.cardview.widget.CardView>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <!-- Judul -->
                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:lineSpacingMultiplier="1.2" />

                    <!-- Tagline -->
                    <TextView
                        android:id="@+id/tv_tagline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_tertiary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-light"
                        android:visibility="gone" />

                    <!-- Rating baris -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★ "
                            android:textColor="@color/brand_red"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" /10"
                            android:textColor="@color/text_tertiary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Tahun · Durasi -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_year"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textColor="@color/text_tertiary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_runtime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Genre chips -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_genres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="4dp"
                        app:chipSpacingVertical="4dp"
                        app:singleLine="false" />

                </LinearLayout>
            </LinearLayout>

            <!-- ── Action Buttons ─────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <!-- Watch Now / Beli Tiket — tombol besar merah -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_watch"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/btn_watch_now"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    style="@style/Widget.CineAI.Button.Primary"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    app:iconTint="@color/text_primary"
                    app:cornerRadius="@dimen/radius_md"
                    android:visibility="gone" />

                <!-- Trailer — tombol outlined -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_trailer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    style="@style/Widget.CineAI.Button.Icon"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    app:iconTint="@color/text_primary"
                    app:cornerRadius="@dimen/radius_md"
                    android:text=""
                    android:visibility="gone" />

                <!-- Watchlist / Bookmark -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_watchlist"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    style="@style/Widget.CineAI.Button.Icon"
                    app:icon="@drawable/ic_bookmark"
                    app:iconGravity="textStart"
                    app:iconTint="@color/text_primary"
                    app:cornerRadius="@dimen/radius_md"
                    android:text="" />

            </LinearLayout>

            <!-- ── Divider ────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="@dimen/page_horizontal_padding" />

            <!-- ── Sinopsis ───────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_synopsis"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="20dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tv_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/page_horizontal_padding"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

            <!-- ── Film Serupa ────────────────────── -->
            <TextView
                android:id="@+id/tv_similar_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_similar"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_similar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/space_12"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Progress bar overlay -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/brand_red"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
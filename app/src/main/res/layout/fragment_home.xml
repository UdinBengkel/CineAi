<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- ══════════════════════════════════════
                 TOP BAR: nama app + ikon notif
                 (tidak pakai Toolbar/AppBar)
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- CINE + AI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name_prefix"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name_suffix"
                        android:textColor="@color/brand_red"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 SECTION: AI PICK / Film yang Mungkin Kamu Suka
                 Tersembunyi saat watchlist kosong
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/section_recommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Label + spinner loading -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/page_horizontal_padding"
                    android:paddingEnd="@dimen/page_horizontal_padding"
                    android:paddingTop="16dp"
                    android:paddingBottom="6dp">

                    <!-- Label "✦ AI PICK FOR YOU" -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_ai_pick"
                        android:textColor="@color/brand_red"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_label_ai"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <ProgressBar
                        android:id="@+id/progress_recommended"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/brand_red" />
                </LinearLayout>

                <!-- Judul section besar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/page_horizontal_padding"
                    android:paddingEnd="@dimen/page_horizontal_padding"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_recommended"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_red"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recommended"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/space_12"
                    android:paddingEnd="@dimen/space_12"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:overScrollMode="never" />

                <!-- Garis pembatas -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginHorizontal="@dimen/page_horizontal_padding"
                    android:layout_marginTop="20dp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 PROGRESS (first load)
                 ══════════════════════════════════════ -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="32dp"
                android:indeterminateTint="@color/brand_red"
                android:visibility="gone" />

            <!-- ══════════════════════════════════════
                 SECTION: Tayang Sekarang
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="24dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_now_playing"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/brand_red"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_12"
                android:paddingEnd="@dimen/space_12"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never" />

            <!-- ══════════════════════════════════════
                 SECTION: Trending Now (Populer)
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="28dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_popular"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/brand_red"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_popular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_12"
                android:paddingEnd="@dimen/space_12"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never" />

            <!-- ══════════════════════════════════════
                 SECTION: Rating Tertinggi
                 ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingTop="28dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_top_rated"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/brand_red"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_top_rated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_12"
                android:paddingEnd="@dimen/space_12"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never" />

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>